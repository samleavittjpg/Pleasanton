{
  "name": "pleasanton",
  "version": "1.0.0",
  "private": true,
  "description": "Pleasanton: HOA PvP neighborhood-builder (web).",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "doctor": "node ./scripts/doctor.cjs",
    "setup": "npm install && npm run doctor",
    "dev": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w web",
    "start": "npm run start -w web"
  },
  "license": "ISC"
}
