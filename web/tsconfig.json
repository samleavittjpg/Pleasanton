{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "/var/folders/dc/qty49k9s42g35fsrd1pbgsq00000gn/T/pleasanton-next-dev-744cefe1b9d5/types/**/*.ts",
    "/var/folders/dc/qty49k9s42g35fsrd1pbgsq00000gn/T/pleasanton-next-dev-744cefe1b9d5/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
